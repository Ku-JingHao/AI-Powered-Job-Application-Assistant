# ============================================================
# AI-Powered Job Application Assistant — Environment Variables
# Copy this file to .env (root) and backend/.env, then fill in
# your actual values. Never commit .env files to version control.
# ============================================================

# ─── Django Backend ─────────────────────────────────────────
# Generate a new key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-django-secret-key-here
DEBUG=True

# ─── Azure Cognitive Services ────────────────────────────────
AZURE_LANGUAGE_KEY=your-azure-language-key
AZURE_LANGUAGE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/

AZURE_VISION_KEY=your-azure-vision-key
AZURE_VISION_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/

AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_ENDPOINT=https://<your-region>.api.cognitive.microsoft.com/
AZURE_SPEECH_REGION=eastus

# ─── Azure Machine Learning ──────────────────────────────────
ML_SUBSCRIPTION_ID=your-azure-subscription-id
ML_RESOURCE_GROUP=your-resource-group-name
ML_WORKSPACE_NAME=your-ml-workspace-name

# ─── Groq AI ────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key

# ─── React Frontend (prefix with REACT_APP_) ────────────────
# These are embedded at build time — do NOT put real secrets here.
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_AZURE_SPEECH_KEY=your-azure-speech-key
REACT_APP_AZURE_SPEECH_REGION=eastus
